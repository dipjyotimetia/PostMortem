{
  "name": "postmortem",
  "displayName": "PostMortem - Postman to Bun Tests",
  "description": "🚀 Generate Bun-native (bun:test + fetch) API tests from Postman collections",
  "version": "2.0.1",
  "publisher": "dipjyotimetia",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dipjyotimetia/PostMortem"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "postman",
    "testing",
    "bun",
    "bun-test",
    "fetch",
    "api"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "postmortem.generateFromCollection",
        "title": "🧪 Generate Tests from Postman Collection",
        "category": "PostMortem"
      },
      {
        "command": "postmortem.generateFromFile",
        "title": "⚡ Generate Tests from Collection File",
        "category": "PostMortem"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "postmortem.generateFromFile",
          "when": "resourceExtname == .json",
          "group": "postmortem"
        }
      ]
    },
    "configuration": {
      "title": "PostMortem",
      "properties": {
        "postmortem.outputDirectory": {
          "type": "string",
          "default": "./tests",
          "description": "Default output directory for generated tests"
        },
        "postmortem.maintainFolderStructure": {
          "type": "boolean",
          "default": true,
          "description": "Maintain Postman collection folder structure"
        },
        "postmortem.generateFullProject": {
          "type": "boolean",
          "default": false,
          "description": "Generate complete test framework with enhanced features"
        },
        "postmortem.createSetupFile": {
          "type": "boolean",
          "default": true,
          "description": "Create setup.ts file for test configuration"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run bundle",
    "build": "bun run bundle",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "pretest": "bun run compile && bun run lint",
    "lint": "biome check src",
    "test": "node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@dipjyotimetia/postmortem": "*"
  }
}
