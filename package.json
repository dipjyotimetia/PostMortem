{
  "name": "@dipjyotimetia/postmortem",
  "version": "2.0.0",
  "description": "Convert Postman collections into Bun-native API tests (bun:test + fetch)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "postmortem": "./dist/cli.cjs"
  },
  "workspaces": [
    "vscode-extension"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "build:extension": "cd vscode-extension && bun run build",
    "build:all": "bun run build && bun run build:extension",
    "clean": "rm -rf dist && cd vscode-extension && rm -rf dist",
    "prebuild": "bun run clean",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./tests",
    "test:watch": "bun test --watch ./tests",
    "test:coverage": "bun test --coverage ./tests",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "convert": "bun run src/cli.ts -c ./collection/Platzi_postman_collection.json -o ./test-output",
    "convert:debug": "bun run src/cli.ts -c ./collection/Platzi_postman_collection.json -o ./test-output --debug",
    "prepublishOnly": "bun run build && bun run test && bun run lint"
  },
  "keywords": [
    "postman",
    "bun",
    "bun-test",
    "fetch",
    "api",
    "testing",
    "conversion",
    "test-automation",
    "cli"
  ],
  "author": "Dipjyoti Metia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dipjyotimetia/PostMortem"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "postman-collection": "^5.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.11",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ]
}
